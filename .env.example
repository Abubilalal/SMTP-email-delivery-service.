# ---- Your domain mailbox SMTP (free, you already own this) ----
# See README for host/port by provider (Zoho, Google Workspace, Outlook, cPanel).
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=you@yourdomain.com
SMTP_PASS=your-app-password

# ---- Sender identity ----
SENDER_EMAIL=you@yourdomain.com
SENDER_NAME=Your Brand
REPLY_TO=you@yourdomain.com

# ---- Unsubscribe (mailto works for free, no hosting needed) ----
UNSUBSCRIBE_MAILTO=unsubscribe@yourdomain.com
# Optional: if you later host a one-click unsubscribe page, put its URL here.
# UNSUBSCRIBE_URL_BASE=https://yourdomain.com/unsubscribe
# UNSUBSCRIBE_SECRET=some-long-random-string

# ---- Sending behaviour ----
SUBJECT=A quick note, {{first_name}}
DELAY=6
